{
  "name": "remtes",
  "productName": "RemTes",
  "version": "1.0.11",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "ro.grumpylabs.remtes",
    "productName": "RemTes",
    "asar": false,
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "tesla-http-proxy.exe",
      "tesla-private-key.pem",
      "proxy-tls-cert.pem",
      "proxy-tls-key.pem",
      "client-secret.txt",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RemTes"
    }
  }
}
